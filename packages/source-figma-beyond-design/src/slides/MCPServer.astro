---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="MCP Server" desc="Read & Write prístup" order={order}>
  <div slot="left">
    <p>
      <strong>Read</strong> — sprístupňuje design ako kontext pre AI agentov.
    </p>
    <p class="text-[0.75em] mt-4 opacity-60 leading-relaxed font-mono">
      whoami, get_libraries, search_design_system, get_design_context, get_metadata, get_variable_defs, get_screenshot, get_code_connect_suggestions, get_context_for_code_connect, get_code_connect_map, get_figjam
    </p>
  </div>
  <div slot="right">
    <p>
      <strong>Write</strong> — umožňuje AI agentom zapisovať a kresliť na Figma canvas.
    </p>
    <p class="text-[0.75em] mt-4 opacity-60 leading-relaxed font-mono">
      use_figma, create_new_file, upload_assets, generate_figma_design, add_code_connect_map, send_code_connect_mappings, create_design_system_rules, generate_diagram
    </p>
  </div>
</Slide>
