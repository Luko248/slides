---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="Výsledný workflow" desc="Od dizajnéra po Git" order={order} center>
  <div style="text-align: center;">
    <ul
      style="text-align: left; display: inline-flex; flex-direction: column; gap: 1rem;"
    >
      <li><span><strong>1.</strong> Dizajnér upraví variables vo Figme</span></li>
      <li><span><strong>2.</strong> Klikne na "Convert Variables"</span></li>
      <li><span><strong>3.</strong> Plugin skonvertuje do CSS (OKLCH, rem)</span></li>
      <li><span><strong>4.</strong> Klikne na "Export to GitHub"</span></li>
      <li><span><strong>5.</strong> Plugin vytvorí feature branch a commit</span></li>
      <li><span><strong>6.</strong> Design tokeny sú v repozitári!</span></li>
    </ul>
  </div>
</Slide>
