---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="Skills pre Figma Agenta" desc="Oficiálne aj od komunity" order={order}>
  <div slot="left">
    <p>
      Základom je skill <strong><code>/figma-use</code></strong>, na ktorom stavajú ostatné. Určuje pravidlá a bezpečné kroky na canvase.
    </p>
    <br />
    <p>
      Oficiálne skills dnes pokrývajú <strong>celý workflow</strong> od návrhu až po kód. Ďalšie stovky nájdete od komunity.
    </p>
  </div>
  <div slot="right">
    <ul style="display: flex; flex-direction: column; gap: 0.75rem; margin-left: 1.5rem; list-style-type: disc;">
      <li><code>/figma-use</code></li>
      <li><code>/figma-create-new-file</code></li>
      <li><code>/figma-generate-library</code></li>
      <li><code>/figma-generate-design</code></li>
      <li><code>/figma-create-design-system-rules</code></li>
      <li><code>/figma-implement-design</code></li>
      <li><code>/figma-code-connect</code></li>
    </ul>
  </div>
</Slide>
