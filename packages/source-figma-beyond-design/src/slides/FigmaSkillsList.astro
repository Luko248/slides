---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="Skills pre Figma Agenta" desc="Oficiálne aj od komunity" order={order}>
  <div slot="left">
    <p>
      Základom je skill <strong><code>/figma-use</code></strong>, na ktorom stavajú ostatné. Určuje pravidlá a bezpečné kroky na canvase.
    </p>
    <br />
    <p>
      Teraz nájdete skills od samotnej Figmy aj od <strong>komunity</strong> (dostupné na <em>figma.com/community/skills</em>).
    </p>
  </div>
  <div slot="right">
    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      <p><strong>Oficiálne skills:</strong></p>
      <ul style="margin-bottom: 1rem;">
        <li><code>/figma-use</code> — základný skill</li>
        <li><code>/figma-generate-design</code> — skladá z existujúcich komponentov</li>
        <li><code>/figma-generate-library</code> — vytvára/updatuje design system</li>
      </ul>
      <p><strong>Z komunity:</strong></p>
      <ul>
        <li><code>/create-voice</code> (Uber) — screen reader specs</li>
        <li><code>/apply-design-system</code> — spája design s komponentmi</li>
        <li><code>/rad-spacing</code> — hierachické odsadenia a premenné</li>
        <li><code>/sync-figma-token</code> — synchronizácia design tokenov</li>
      </ul>
    </div>
  </div>
</Slide>
