---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="Zhrnutie" desc="Design-to-code ecosystem" order={order}>
  <div slot="left">
    <ul style="display: flex; flex-direction: column; gap: 1rem;">
      <li>
        <strong>Variable Code Syntax</strong> — Figma premenné priamo v kóde
      </li>
      <li>
        <strong>Export Automation</strong> — plugin exportuje tokeny do Gitu
      </li>
      <li>
        <strong>Code Connect</strong> — mapping Figma komponentov na codebase
      </li>
    </ul>
  </div>
  <div slot="right">
    <ul style="display: flex; flex-direction: column; gap: 1rem;">
      <li>
        <strong>MCP Server</strong> — AI generuje kód z dizajnu
      </li>
      <li>
        <strong>Agent SKILLS</strong> — konzistentné AI správanie
      </li>
    </ul>
  </div>
</Slide>
