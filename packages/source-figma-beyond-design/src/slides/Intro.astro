---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide
  title="Figma nie je len pre dizajnérov"
  desc="Plnohodnotná platforma"
  order={order}
  center
>
  <p class="text-center">
    Zaisťuje jednotný <strong>"language"</strong> pre dizajnérov, vývojárov a AI agentov.
  </p>
  <br />
  <p class="text-center">
    Figma je plnohodnotná platforma s <strong>AI automatizáciou</strong>, <strong
      >API</strong
    > a <strong>pluginmi</strong>.
  </p>
  <br />
  <p class="text-center">
    <strong>code-to-design</strong>, <strong>design-to-code</strong>, <strong
      >prompt-to-design</strong
    > a ďalšie workflows.
  </p>
</Slide>
