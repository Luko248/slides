---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="Figma nie je len pre dizajnérov" desc="3 vrstvy jedného workflow" order={order} center>
  <p class="text-center">
    Figma je plnohodnotná platforma s <strong>API</strong>, <strong>pluginmi</strong> a <strong>automatizáciou</strong>.
  </p>
  <br />
  <p class="text-center">
    V tejto prezentácii sú 3 roviny: <strong>tokeny</strong>, <strong>mapping dizajnu na kód</strong> a <strong>AI workflow nad canvasom</strong>.
  </p>
</Slide>
