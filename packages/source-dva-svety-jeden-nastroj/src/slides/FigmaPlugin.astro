---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="Plugin export tokenov" desc="Čo existuje a čo z toho máme" order={order}>
  <div slot="left">
    <strong class="block mb-[2svh]">Ako funguje</strong>
    <ul style="display: flex; flex-direction: column; gap: 0.75rem;">
      <li><span>Plugin načíta variables z Figmy</span></li>
      <li><span>Premapuje ich na tokeny pre web/codebase</span></li>
      <li><span>Vygeneruje výstupné súbory a pošle ich do repozitára</span></li>
      <li><span>Výsledkom je konzistentný most medzi design systémom a kódom</span></li>
    </ul>
  </div>
  <div slot="right">
    <strong class="block mb-[2svh]">Výhody</strong>
    <ul style="display: flex; flex-direction: column; gap: 0.75rem;">
      <li><span><strong>Plus:</strong> menej copy-paste, menej naming chýb, rýchlejší handoff</span></li>
      <li><span><strong>Plus:</strong> jeden zdroj pravdy pre tokeny a témy</span></li>
      <li><span><strong>Plus:</strong> tokeny sa dostanú z Figmy do codebase konzistentne a opakovateľne</span></li>
      <li><span><strong>Plus:</strong> tím sa môže sústrediť viac na rozhodnutia než na ručný export</span></li>
    </ul>
  </div>
</Slide>
