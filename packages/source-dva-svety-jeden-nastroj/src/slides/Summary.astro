---
import Slide from "@presentation/components/slide/Slide.astro";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide title="Zhrnutie" desc="3 vrstvy jedného systému" order={order}>
  <div slot="left">
    <ul style="display: flex; flex-direction: column; gap: 1rem;">
      <li>
        <strong>1. Tokeny</strong> — Variable Code Syntax a export držia naming aj hodnoty konzistentné
      </li>
      <li>
        <strong>2. Komponenty</strong> — Code Connect mapuje Figma komponenty na reálnu codebase
      </li>
      <li>
        <strong>3. Agenti</strong> — MCP + skills dávajú AI kontext aj pravidlá pre kvalitný output
      </li>
    </ul>
  </div>
  <div slot="right">
    <p>
      Výsledok nie je len rýchlejší handoff.
    </p>
    <br />
    <p>
      Je to <strong>jeden prepojený systém</strong>, kde dizajn, kód aj AI pracujú
      nad rovnakými komponentmi, tokenmi a pravidlami.
    </p>
    <br />
    <p>
      Presne v tom je <strong>dva svety - jeden nástroj</strong>.
    </p>
  </div>
</Slide>
