---
import Slide from "@presentation/components/slide/Slide.astro";
import imageSrc from "../assets/ds.jpeg?url";

interface Props {
  order?: number;
}

const { order } = Astro.props;
---

<Slide order={order} center>
  <Fragment slot="title">
    <img
      src={imageSrc}
      alt="Design system diagram"
      class="mx-auto h-[85svh] w-[85%] object-contain rounded-[.25em]"
    />
  </Fragment>
</Slide>
